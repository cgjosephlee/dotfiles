{
  "title": "Custom 4: Navigation in Terminal Apps (emacs mode)",
  "rules": [
    {
      "description": "Cmd + Left | Move cursor to line begin",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_arrow",
            "modifiers": {
              "mandatory": [
                "command"
              ]
            }
          },
          "to": [
            {
              "key_code": "a",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Cmd + Right | Move cursor to line end",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_arrow",
            "modifiers": {
              "mandatory": [
                "command"
              ]
            }
          },
          "to": [
            {
              "key_code": "e",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Opt + Left | Move cursor one word behind",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "left_arrow",
            "modifiers": {
              "mandatory": [
                "option"
              ]
            }
          },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "key_code": "b"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Opt + Right | Move cursor one word ahead",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "right_arrow",
            "modifiers": {
              "mandatory": [
                "option"
              ]
            }
          },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "key_code": "f"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Opt + Del | Delete one word",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": [
                "option"
              ]
            }
          },
          "to": [
            {
              "key_code": "w",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Opt + Fn+Del | Delete one word ahead",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": [
                "option",
                "fn"
              ]
            }
          },
          "to": [
            {
              "key_code": "escape"
            },
            {
              "key_code": "d"
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Cmd + Del | Delete to line begin",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": [
                "command"
              ]
            }
          },
          "to": [
            {
              "key_code": "u",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    },
    {
      "description": "Cmd + Fn+Del | Delete to line end",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "delete_or_backspace",
            "modifiers": {
              "mandatory": [
                "command",
                "fn"
              ]
            }
          },
          "to": [
            {
              "key_code": "k",
              "modifiers": [
                "left_control"
              ]
            }
          ],
          "conditions": [
            {
              "type": "frontmost_application_if",
              "bundle_identifiers": [
                "^com\\.apple\\.Terminal$",
                "^net\\.kovidgoyal\\.kitty$",
                "^com\\.mitchellh\\.ghostty$"
              ]
            }
          ]
        }
      ]
    }
  ]
}
